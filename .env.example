# Shared access key — anyone with this key can use the tool.
# Change for production.
CH_ACCESS_KEY=choicehammer-dev-key

# Backend
CH_HTTP_ADDR=:8080
CH_POSTGRES_DSN=postgres://choicehammer:choicehammer@localhost:5432/choicehammer?sslmode=disable
CH_LOG_DIR=logs
CH_LOG_LEVEL=info
CH_LOG_PRETTY=true
CH_MAX_VUS=50000

# Frontend (Vite)
VITE_API_URL=http://localhost:8080

# Admin
CH_ADMIN_KEY=97886

# ────────────────────────────────────────────────────────────────────────
# Jira integration — used by APIStress's "Attach report to Jira" button.
# Leave all blank to disable; the UI hides the feature gracefully.
#
# Atlassian Cloud (most likely):
#   1. Generate a token: https://id.atlassian.com/manage-profile/security/api-tokens
#   2. CH_JIRA_AUTH_KIND=cloud_basic
#   3. CH_JIRA_EMAIL = Atlassian account email
#   4. CH_JIRA_API_TOKEN = the API token
#
# Self-hosted Jira Server / Data Center:
#   1. Create a Personal Access Token in your profile
#   2. CH_JIRA_AUTH_KIND=server_pat
#   3. CH_JIRA_EMAIL is unused
#   4. CH_JIRA_API_TOKEN = the PAT
# ────────────────────────────────────────────────────────────────────────
CH_JIRA_BASE_URL=
CH_JIRA_AUTH_KIND=cloud_basic
CH_JIRA_EMAIL=
CH_JIRA_API_TOKEN=
# Optional: only allow attaches to issues in this project key (e.g. CT)
CH_JIRA_PROJECT_KEY=

# ────────────────────────────────────────────────────────────────────────
# Hardening / security knobs
# ────────────────────────────────────────────────────────────────────────
# CORS allow-list — comma-separated origins. Leave blank in dev (allow-all).
# Production example:
#   CH_ALLOWED_ORIGINS=https://tools.choicetechlab.com,https://internal.choicetechlab.com
CH_ALLOWED_ORIGINS=

# Hard cap on JSON / form / curl-string upload size. Default 32 MiB.
CH_MAX_REQUEST_BYTES=33554432

# Kavach SSRF gate. By default the VAPT scanner refuses to fan attack
# payloads at loopback / RFC1918 / link-local hosts. Set to true ONLY on
# internal-only deployments where probing internal infra is the intent.
CH_KAVACH_ALLOW_PRIVATE=false

# Gin runtime mode. release | debug | test. Stick to release in prod —
# debug mode logs the route table on stdout.
CH_GIN_MODE=release
